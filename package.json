{
  "name": "@hep-fcc/root2gltf",
  "version": "1.3.3",
  "description": "Convert detector geometries from ROOT to the glTF format used by Phoenix",
  "keywords": [
    "ROOT",
    "glTF",
    "Detector",
    "Phoenix"
  ],
  "homepage": "https://github.com/HEP-FCC/root2gltf",
  "bugs": {
    "url": "https://github.com/HEP-FCC/root2gltf/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HEP-FCC/root2gltf.git"
  },
  "license": "BSD-2-Clause",
  "type": "module",
  "exports": "./dist/src/index.js",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "root2gltf": "bin/cli.js"
  },
  "files": [
    "bin",
    "dist/src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "npx eslint . --quiet",
    "lint:fix": "npx eslint . --fix",
    "prepublishOnly": "npm run lint && npm run test"
  },
  "dependencies": {
    "jsroot": "^7.10.3",
    "three": "^0.183.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^29.7.0",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "authors": [
    "Juraj Smiesko",
    "Pablo Apausa"
  ]
}
